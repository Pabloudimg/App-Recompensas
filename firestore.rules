rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // REGRAS TEMPORÁRIAS DE DESENVOLVIMENTO
    // Objetivo: isolar se o travamento está vindo das regras do Firestore.
    // Depois que o fluxo de login/família/convites estabilizar, vamos voltar para regras restritivas por família.

    match /userProfiles/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /familyInvites/{inviteId} {
      allow read, write: if signedIn();
    }

    match /families/{familyId} {
      allow read, write: if signedIn();

      match /{document=**} {
        allow read, write: if signedIn();
      }
    }
  }
}
